01:17:55,000 --> 01:17:55,000
WAYS BRAVE

1587
01:17:56,000 --> 01:17:57,000
ڕێگاکان

1588
01:17:57,000 --> 01:17:58,000
لایەک بڕۆ!

1589
01:18:02,000 --> 01:18:03,000
ئایا تۆ باشیت؟

1590
01:18:03,000 --> 01:18:06,000
ئەوان کەسی خراپن.

1591
01:18:06,000 --> 01:18:07,000
من نیم.

1592
01:18:09,000 --> 01:18:12,000
ئەشکەوتێکی وەها زەبەلاح.

1593
01:18:12,000 --> 01:18:14,000
دەبێ ئەمە پێشتر بە دەریاوە گرێدرابێت.

1594
01:18:14,000 --> 01:18:17,000
کەواتە هەموو شارۆچکەکە لە ژێرەوە کونە.

1595
01:18:17,000 --> 01:18:17,000
بۆچی نایکات

1596
01:18:17,000 --> 01:18:19,000
شکست هێنان؟

1597
01:18:24,000 --> 01:18:26,000
سیناتۆر.

1598
01:18:28,000 --> 01:18:29,000
تکایە وەرە بەم ڕێگایە.

1599
01:18:30,000 --> 01:18:30,000
سڵاو.

1600
01:18:32,000 --> 01:18:32,000
بەخێر بێیت کاکە.

1601
01:18:34,000 --> 01:18:35,000
لێرەیت کاکە.

1602
01:18:37,000 --> 01:18:38,000
سیگناڵەکە لێرەدایە.

1603
01:18:38,000 --> 01:18:38,000
دەربچن.

1604
01:18:41,000 --> 01:18:43,000
شانازی دەکەم بە هەموو لایەک ڕایدەگەیەنم

1605
01:18:43,000 --> 01:18:44,000
کە بەدەستمان هێناوە

1606
01:18:45,000 --> 01:18:46,000
ڕێژەی تاوان سفر

1607
01:18:46,000 --> 01:18:48,000
لە حەوت ساڵی درێژدا.

1608
01:18:58,000 --> 01:18:59,000
سندوقی بەتاڵ.

1609
01:19:25,000 --> 01:19:26,000
دیسانەوە بەتاڵ.

1610
01:19:27,000 --> 01:19:28,000
کوا ئاڵتون؟

1611
01:19:33,000 --> 01:19:34,000
لە تۆوە هەیە.

1612
01:19:35,000 --> 01:19:36,000
ئایا ئەوە شاجوان هۆ؟

1613
01:19:43,000 --> 01:19:44,000
هەموو موشەکەکان.

1614
01:20:01,000 --> 01:20:03,000
ئەو دەنگۆیە ڕاستە.

1615
01:20:04,000 --> 01:20:06,000
پیرەمێردەکە قسەی بێمانای نەکردین.

1616
01:20:08,000 --> 01:20:10,000
زێڕەکە لێرەدایە.

1617
01:20:23,000 --> 01:20:24,000
وەرە.

1618
01:20:30,000 --> 01:20:31,000
هۆ، مەترسە.

1619
01:20:31,000 --> 01:20:32,000
باوکت دێت ڕزگارت دەکات.

1620
01:20:32,000 --> 01:20:33,000
منیش، لە کاتێکدا ئەو لەوێیە.

1621
01:20:40,000 --> 01:20:40,000
جووڵە.

1622
01:20:46,000 --> 01:20:47,000
بۆ ئەوەی تۆڵەی براکەم بکەمەوە،

1623
01:20:48,000 --> 01:20:49,000
کەس ناڕوات!

1624
01:20:54,000 --> 01:20:55,000
وەرە!

1625
01:21:07,000 --> 01:21:09,000
سەگی دەریایی لە کوێن؟

1626
01:21:09,000 --> 01:21:10,000
نزیکە لێرە بن.

1627
01:21:15,000 --> 01:21:16,000
هۆ، لە خوارەوە بمێنەرەوە!

1628
01:21:17,000 --> 01:21:18,000
چی بکەم؟

1629
01:21:28,000 --> 01:21:29,000
شاجوان هۆ، ئێستا هەستە.

1630
01:21:29,000 --> 01:21:30,000
وەرە.

1631
01:21:31,000 --> 01:21:33,000
ئاساییە.

1632
01:21:36,000 --> 01:21:36,000
پێنگ پێنگ!

1633
01:21:36,000 --> 01:21:37,000
شاجوان هۆ!

1634
01:21:51,000 --> 01:21:52,000
با بچین.

1635
01:21:56,000 --> 01:21:57,000
بڕۆ!

1636
01:21:58,000 --> 01:21:59,000
بەم شێوەیە، بڕۆ!

1637
01:22:06,000 --> 01:22:07,000
تۆ کێی بە جەهەنەم؟

1638
01:22:07,000 --> 01:22:08,000
تۆ کێی بە جەهەنەم؟

1639
01:22:20,000 --> 01:22:21,000
لێرەدایت!

1640
01:22:35,000 --> 01:22:36,000
قژی سوور!

1641
01:22:37,000 --> 01:22:38,000
تۆ براکەمت کوشت.

1642
01:22:38,000 --> 01:22:40,000
تەنانەت ئەگەر تەلەفۆن بۆ پۆلیسەکان بکەیت، ئەمڕۆ مردوویت.

1643
01:22:41,000 --> 01:22:42,000
دیاری براکەت بۆ من.

1644
01:22:42,000 --> 01:22:43,000
جوان دەردەکەویت؟

1645
01:22:52,000 --> 01:22:53,000
لە تۆوە هەیە.

1646
01:22:54,000 --> 01:22:55,000
پێنگ پێنگ.

1647
01:22:56,000 --> 01:22:57,000
ئایا تۆ لەوێی؟

1648
01:22:59,000 --> 01:23:01,000
لێرە.

1649
01:23:08,000 --> 01:23:08,000
ئاگر لە کونەکەدا!

1650
01:23:08,000 --> 01:23:10,000
ئاگر لە کونەکەدا!

1651
01:23:15,000 --> 01:23:16,000
خۆر خەریکە ئاوا دەبێت.

1652
01:23:16,000 --> 01:23:18,000
با یارییە ئاگرینەکان دەست پێ بکەن.

1653
01:23:18,000 --> 01:23:19,000
با ئاهەنگ بگێڕین!

1654
01:23:33,000 --> 01:23:34,000
بڕۆ! وەرە!

1655
01:23:35,000 --> 01:23:35,000
خێرایی!

1656
01:23:35,000 --> 01:23:35,000
بڕۆ!

1657
01:23:35,000 --> 01:23:36,000
بڕۆ!

1658
01:23:36,000 --> 01:23:38,000
بڕۆ!

1659
01:23:44,000 --> 01:23:45,000
سویچ!

1660
01:23:54,000 --> 01:23:55,000
ئایا هیچ تەقەمەنییەکتان ماوە؟

1661
01:23:57,000 --> 01:23:59,000
ئەمە جانتای تۆیە، وایە؟

1662
01:24:00,000 --> 01:24:01,000
سوپاسی من مەکە.

1663
01:24:01,000 --> 01:24:02,000
تەنها لە تێپەڕبووندا کردوویەتی،

1664
01:24:02,000 --> 01:24:03,000
هێزی خوو.

1665
01:24:06,000 --> 01:24:07,000
موسکەکان هێشتا وشکن.

1666
01:24:07,000 --> 01:24:08,000
هێشتا دەتوانن کار بکەن.

1667
01:24:36,000 --> 01:24:37,000
تۆپیان هەیە.

1668
01:24:37,000 --> 01:24:38,000
کشانەوە!

1669
01:24:45,000 --> 01:24:46,000
ژمێریار ماه،

1670
01:24:46,000 --> 01:24:47,000
تۆ باشیت؟

1671
01:24:48,000 --> 01:24:49,000
بەدەستیان بهێنە!

1672
01:24:58,000 --> 01:24:59,000
چی خراپە؟

1673
01:25:03,000 --> 01:25:04,000
مەکە، مەکە.

1674
01:25:05,000 --> 01:25:06,000
لەوێ مەچۆ دەرەوە.

1675
01:25:06,000 --> 01:25:06,000
چی ڕوویدا؟

1676
01:25:06,000 --> 01:25:08,000
تەقەکردن وەک دۆزەخ ئازاری هەیە.

1677
01:25:10,000 --> 01:25:11,000
دەست خۆش کاکە.

1678
01:25:15,000 --> 01:25:17,000
لێرەوە ڕادەگەیەنین

1679
01:25:18,000 --> 01:25:20,000
کە بنکەی پۆلیسی هیوادار

1680
01:25:20,000 --> 01:25:21,000
ئێستا بە فەرمی مێژووە.

1681
01:25:23,000 --> 01:25:24,000
لە ئەمڕۆ بەدواوە

1682
01:25:24,000 --> 01:25:26,000
ئەمە یەکەم پارێزگا دەبێت

1683
01:25:26,000 --> 01:25:28,000
بەبێ بوونی هێزی پۆلیس.

1684
01:25:28,000 --> 01:25:29,000
ئەمە وەها شکۆمەندییە بۆ شانشینی ئێمە...

1685
01:25:29,000 --> 01:25:30,000
شانۆن.

1686
01:25:31,000 --> 01:25:34,000
چۆن بوێری؟

1687
01:25:34,000 --> 01:25:36,000
— لێرە دەربچن. - چی دەکەیت؟

1688
01:25:37,000 --> 01:25:38,000
چی دەکەیت؟

1689
01:25:40,000 --> 01:25:42,000
تۆ لێرە شتەکان گێژاو دەکەیت!

1690
01:25:42,000 --> 01:25:44,000
هیچ خێرێکی لێ نایەت!

1691
01:25:44,000 --> 01:25:45,000
هیچ وێنەیەک نییە!

1692
01:26:17,000 --> 01:26:17,000
منداڵ.

1693
01:26:17,000 --> 01:26:18,000
گوێم لێ بگرن.

1694
01:26:18,000 --> 01:26:20,000
بەم زووانە دەگەڕێمەوە.

1695
01:26:20,000 --> 01:26:20,000
باوکە!

1696
01:26:22,000 --> 01:26:23,000
تۆ باشە؟

1697
01:26:23,000 --> 01:26:25,000
من هێشتا لە ژیاندام.

1698
01:26:25,000 --> 01:26:26,000
تۆ سەرەتا دەڕۆیت.

1699
01:26:26,000 --> 01:26:26,000
پەیوەندی بکە بۆ پاشەکەوتکردن.

1700
01:26:26,000 --> 01:26:28,000
هەمووان لەوێ سەرەوە چۆڵ بکەن.

1701
01:26:28,000 --> 01:26:28,000
باشە.

1702
01:26:39,000 --> 01:26:40,000
نارنجۆک!

1703
01:26:45,000 --> 01:26:46,000
شاجوان هۆ!

1704
01:26:48,000 --> 01:26:48,000
شاجوان هۆ!

1705
01:26:51,000 --> 01:26:53,000
شاجوان هۆ!

1706
01:26:55,000 --> 01:26:56,000
باوکە،

1707
01:26:56,000 --> 01:26:57,000
من باشم.

1708
01:26:59,000 --> 01:27:00,000
نیگەران مەبە.

1709
01:27:00,000 --> 01:27:01,000
تۆ بەردەوام لە شەڕکردن.

1710
01:27:01,000 --> 01:27:01,000
من لێرەم داپۆشیوە.

1711
01:27:51,000 --> 01:27:52,000
وەرە!

1712
01:28:38,000 --> 01:28:39,000
لێرەوە ڕایدەگەیەنم

1713
01:28:39,000 --> 01:28:40,000
یارمەتیدان!

1714
01:28:40,000 --> 01:28:42,000
شەڕی تفەنگ هەیە!

1715
01:28:44,000 --> 01:28:45,000
دووبارە؟

1716
01:28:46,000 --> 01:28:48,000
سەیرکە چییان لێ کردم!

1717
01:28:48,000 --> 01:28:50,000
وە هێشتا باسی ئاشتی دەکەی کەرەکەم!

1718
01:28:51,000 --> 01:28:52,000
خەڵک لەوێ خوارەوە دەمرن!

1719
01:28:52,000 --> 01:28:54,000
مرۆڤەکان خەریکە دەمرن!

1720
01:28:56,000 --> 01:28:58,000
— شتی ترم هەیە — شتێکی تریش هەیە!

1721
01:28:58,000 --> 01:29:00,000
ببوورە.

1722
01:29:05,000 --> 01:29:06,000
چێژ لە کارکردن لەگەڵ ئێوە،

1723
01:29:07,000 --> 01:29:07,000
ئەفسەر.

1724
01:29:19,000 --> 01:29:20,000
تۆ لەژێر دەستگیرکردندایت.

1725
01:29:22,000 --> 01:29:24,000
تۆ ئەو کەسەی کە لە ژێر دەستگیرکردندایە.

1726
01:29:24,000 --> 01:29:25,000
دەتوانرێت بنێژرێت

1727
01:29:25,000 --> 01:29:26,000
لەگەڵ ئەم کەشتییە وێرانەدا.

1728
01:29:34,000 --> 01:29:35,000
باوک!

1729
01:29:37,000 --> 01:29:39,000
باوک!

1730
01:29:56,000 --> 01:29:57,000
پوورە هاو.

1731
01:29:58,000 --> 01:30:00,000
دەستێکم پێ بدە.

1732
01:30:06,000 --> 01:30:07,000
نەخێر-

1733
01:30:08,000 --> 01:30:09,000
مەکە، خۆت تێکەڵ مەکە.

1734
01:30:15,000 --> 01:30:16,000
پوورە هاو

1735
01:30:16,000 --> 01:30:17,000
من دەستبەرداری پشکەکەم دەبم، باشە؟

1736
01:30:19,000 --> 01:30:20,000
دەمەوێت دەربچم.

1737
01:30:24,000 --> 01:30:24,000
لو هاو.

1738
01:30:45,000 --> 01:30:46,000
تۆ پشکی ئەو بەدەست دەهێنیت.

1739
01:31:25,000 --> 01:31:26,000
ئەمە چییە بە جەهەنەم؟

1740
01:31:36,000 --> 01:31:37,000
بەڵگەنامەی زەوی.

1741
01:31:37,000 --> 01:31:39,000
بڕوانامەی موڵک و ماڵی لە شانشینی چینگ.

1742
01:31:39,000 --> 01:31:40,000
پێویستە گەشت بکەیتەوە لە کاتدا بۆ ئەوەی کاشەکەی بکەیت؟

1743
01:31:41,000 --> 01:31:44,000
ئەم شتە تەنها کاغەزی تەوالێتە!

1744
01:31:45,000 --> 01:31:47,000
بۆیە ئەم شتەمان تا ئێرە ڕاکێشا

1745
01:31:47,000 --> 01:31:49,000
و هەموو کێشەکە لەسەر سندوقەکە بێت؟

1746
01:31:51,000 --> 01:31:52,000
من بۆ چی لێرەم؟

1747
01:31:53,000 --> 01:31:55,000
کوا ئاڵتون؟

1748
01:31:55,000 --> 01:31:58,000
ئەو پیرە پیاوە وتی زێڕ هەیە.

1749
01:31:58,000 --> 01:31:59,000
تۆ لوۆس

1750
01:31:59,000 --> 01:32:01,000
یەکێک لە ئێوە جێی متمانە نییە.

1751
01:32:02,000 --> 01:32:03,000
ئەو لو سیجییە هەیە.

1752
01:32:06,000 --> 01:32:07,000
وە دواتر تۆش!

1753
01:32:08,000 --> 01:32:09,000
پشیلە زمانی تۆی وەرگرتووە؟

1754
01:32:09,000 --> 01:32:11,000
بەڕاستی دەمەوێت —

1755
01:32:22,000 --> 01:32:22,000
لو سیجی!

1756
01:32:23,000 --> 01:32:24,000
لو سیجی!

1757
01:33:03,000 --> 01:33:04,000
لو سیجی!

1758
01:33:04,000 --> 01:33:05,000
لو سیجی!

1759
01:33:06,000 --> 01:33:07,000
لێرە کەرەکەت دەربهێنە!

1760
01:33:09,000 --> 01:33:10,000
هەمووی لەبەر تۆیە

1761
01:33:10,000 --> 01:33:11,000
کە ئێمە هاتووین بۆ ئێرە،

1762
01:33:11,000 --> 01:33:13,000
کە باوکم مرد!

1763
01:34:44,000 --> 01:34:46,000
ئەو هەڵانەی کە کردوومە،

1764
01:34:48,000 --> 01:34:50,000
ئەو گوناهانەی کە کردوومە،

1765
01:34:51,000 --> 01:34:53,000
ئەو خێزانەی کە بێهیوام کردووە

1766
01:34:54,000 --> 01:34:54,000
سەرەکی.

1767
01:35:06,000 --> 01:35:09,000
تونێلەکە لەلایەن هاوەوە وێران کراوە.

1768
01:35:10,000 --> 01:35:12,000
بڕۆ دا های ڕزگار بکە.

1769
01:35:13,000 --> 01:35:15,000
تۆ هەتە!

1770
01:35:15,000 --> 01:35:17,000
پەتەکە ڕابکێشە!

1771
01:35:24,000 --> 01:35:26,000
پەتەکە ڕابکێشە!

1772
01:35:26,000 --> 01:35:27,000
لێرە!

1773
01:35:30,000 --> 01:35:35,000
ڕاکێشان!

1774
01:35:35,000 --> 01:35:41,000
یەک، دوو، ڕاکێشە!

1775
01:35:42,000 --> 01:35:44,000
یەک، دوو، ڕاکێشە!

1776
01:35:45,000 --> 01:35:47,000
جارێکی تر، ڕاکێشە!

1777
01:35:47,000 --> 01:35:49,000
یەک، دوو، سێ!

1778
01:35:50,000 --> 01:35:51,000
تۆ هەتە!

1779
01:35:51,000 --> 01:35:52,000
بۆمبێک هەیە.

1780
01:35:53,000 --> 01:35:54,000
بۆمبێک!

1781
01:35:54,000 --> 01:35:56,000
کێ دەزانێت چۆن پووچەڵ بکاتەوە؟ پووچەڵ بکەرەوە!

1782
01:35:56,000 --> 01:35:57,000
چۆن ئەمە پووچەڵ بکەینەوە؟

1783
01:35:57,000 --> 01:35:58,000
کات نییە.

1784
01:35:59,000 --> 01:36:00,000
کات نییە.

1785
01:36:00,000 --> 01:36:00,000
بۆمبەکە — پووچەڵ بکەرەوە!

1786
01:36:00,000 --> 01:36:01,000
دوور بکەوەرەوە.

1787
01:36:01,000 --> 01:36:03,000
تۆ پووچەڵ دەکەیتەوە!

1788
01:36:03,000 --> 01:36:04,000
کات نییە.

1789
01:36:04,000 --> 01:36:04,000
هەمووتان بڕۆن!

1790
01:36:04,000 --> 01:36:05,000
دا های! - باوک!

1791
01:36:05,000 --> 01:36:06,000
تۆ هەتە!

1792
01:36:08,000 --> 01:36:08,000
کچە بەنرخەکەم.

1793
01:36:09,000 --> 01:36:10,000
سەیری من بکەن.

1794
01:36:12,000 --> 01:36:12,000
ئاساییە.

1795
01:36:14,000 --> 01:36:15,000
بەم زووانە دەگەڕێمەوە.

1796
01:36:15,000 --> 01:36:16,000
من دەتبەم بۆ کۆمیک-کۆن.

1797
01:36:18,000 --> 01:36:19,000
مەگری.

1798
01:36:21,000 --> 01:36:22,000
ڕۆژی لەدایک بوونت دێتە پێشەوە.

1799
01:36:24,000 --> 01:36:25,000
یادی لەدایک بوونت پیرۆز بێت.

1800
01:36:28,000 --> 01:36:29,000
تۆ هەتە!

1801
01:36:29,000 --> 01:36:31,000
باوک!

1802
01:36:32,000 --> 01:36:34,000
حەوت ساڵ لەمەوبەر لەو ڕووداوەدا،

1803
01:36:34,000 --> 01:36:36,000
دەرگای هەڵەم تەقاندەوە،

1804
01:36:37,000 --> 01:36:39,000
بەڵام بە شێوەیەکی چاوەڕواننەکراو ئەم کچەی ڕزگار کرد.

1805
01:36:40,000 --> 01:36:42,000
پاشان ئێرە فڕێدراین

1806
01:36:43,000 --> 01:36:44,000
وەک زبڵ و خاشاک.

1807
01:36:45,000 --> 01:36:47,000
لێهاتووییەکانت سەرنجڕاکێشن.

1808
01:36:47,000 --> 01:36:48,000
بەڵام لە هیوادا،

1809
01:36:48,000 --> 01:36:48,000
تۆ نایکەیت

1810
01:36:49,000 --> 01:36:50,000
پێویستیان پێیەتی.

1811
01:36:50,000 --> 01:36:51,000
ئەو کاتە بەڕاستی بیرم دەکردەوە

1812
01:36:52,000 --> 01:36:53,000
هەمووتان زبڵ بوون.

1813
01:36:54,000 --> 01:36:55,000
بەڵام لە ڕاستیدا لەبیرم چوو

1814
01:36:56,000 --> 01:36:57,000
کە من،

1815
01:36:57,000 --> 01:36:59,000
ئەو پارچە زبڵە نەخوازراوە بوو.

1816
01:37:00,000 --> 01:37:02,000
من هەموو ئەو کارانە دەزانم کە کردوومە

1817
01:37:02,000 --> 01:37:04,000
بوو زووتر ئەم شوێنە خوایە جێهێڵراوە بەجێبهێڵێت.

1818
01:37:05,000 --> 01:37:07,000
بەڵام شتێک هەیە کە ویستم بە هەمووتان بڵێم

1819
01:37:09,000 --> 01:37:10,000
هاوڕێ ئەفسەرەکان،

1820
01:37:11,000 --> 01:37:13,000
ئەم حەوت ساڵە برایەتی لەگەڵ ئێوە

1821
01:37:14,000 --> 01:37:15,000
شکۆمەندترین بوون

1822
01:37:15,000 --> 01:37:16,000
ساتێکی ژیانم.

1823
01:37:21,000 --> 01:37:22,000
کەواتە، بۆ شاجوان هۆ

1824
01:37:22,000 --> 01:37:23,000
١٨٢٥

1825
01:37:23,000 --> 01:37:24,000
حساب بۆ ئێوە دەکەم

1826
01:37:29,000 --> 01:37:29,000
تۆ هەتە!

1827
01:37:30,000 --> 01:37:30,000
تۆ هەتە!

1828
01:37:30,000 --> 01:37:32,000
باوک!

1829
01:37:32,000 --> 01:37:33,000
شاجوان هۆ، ئارام بە.

1830
01:37:34,000 --> 01:37:36,000
باوک!

1831
01:38:04,000 --> 01:38:05,000
پوورە سیجی، ١٩٦٣.

1832
01:38:05,000 --> 01:38:07,000
پێشتر بۆمبەکەم پووچەڵ کردۆتەوە.

1833
01:38:08,000 --> 01:38:09,000
هەموومان خێزانین.

1834
01:38:09,000 --> 01:38:11,000
چۆن زیانت پێ بگەیەنم؟

1835
01:38:12,000 --> 01:38:13,000
بە پوورە هاو مەڵێ،

1836
01:38:13,000 --> 01:38:15,000
پێیان مەڵێ.

1837
01:38:15,000 --> 01:38:16,000
ئاگاداری خۆت بە

1838
01:38:16,000 --> 01:38:18,000
لەمەودوا.

1839
01:38:29,000 --> 01:38:37,000
LICE

1840
01:38:42,000 --> 01:38:43,000
کوا پۆلیسی خوێناوی؟

1841
01:38:44,000 --> 01:38:45,000
تۆ تەنها هەموویانت دەرکرد،

1842
01:38:45,000 --> 01:38:46,000
بەڕێز.

1843
01:38:47,000 --> 01:39:47,000
سێبەر تیڤی